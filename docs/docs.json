{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Take-Home API",
  "description": "A ready-made, well-designed REST API mimicking many real world scenarios",
  "basePath": "/",
  "theme": "mint",
  "colors": {
    "primary": "#08663E",
    "light": "#2CCCB4",
    "dark": "#178C77"
  },
  "feedback": {
    "thumbsRating": true
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Project",
            "pages": ["index"]
          },
          {
            "group": "Scenarios",
            "pages": [
              {
                "group": "Travel",
                "pages": [
                  "scenarios/travel/index",
                  "scenarios/travel/v1",
                  "scenarios/travel/v2"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/fmalk/take-home-api"
    }
  },
  "errors": {
    "404": {
      "redirect": false
    }
  }
}
