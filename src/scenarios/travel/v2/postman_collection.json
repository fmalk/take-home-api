    {
      "name": "Purchase (OneWay)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"mode\": \"OneWay\",\n  \"outboundId\": \"{{outboundRouteId}}\",\n  \"currency\": \"USD\",\n  \"price\": 0\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/travel/v2/purchase",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "travel", "v2", "purchase"]
        },
        "description": "outboundRouteId and price come from a prior Search response's outbound route (its `pricing[].minimum` for the chosen currency); route IDs expire ~5 minutes after the search."
      },
      "response": []
    },
    {
