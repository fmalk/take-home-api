{
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "overrides": [
    {
      "files": ["*.md", "*.mdx"],
      "options": {
        "proseWrap": "never",
        "embeddedLanguageFormatting": "auto"
      }
    },
    {
      "files": ["*.json"],
      "options": {
        "printWidth": 120,
        "tabWidth": 2,
        "useTabs": false
      }
    }
  ]
}
