{
  "name": "take-home-api",
  "version": "0.1.0",
  "description": "A ready-made, well-designed REST API mimicking many real world scenarios. Every scenario has API versions of increased difficulty.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node src/scripts/dev.cjs",
    "start": "node dist/index.js",
    "build": "esbuild src/index.ts --bundle --platform=node --target=ES2022 --format=esm --outfile=dist/index.js --sourcemap",
    "preview": "npm run build && npm start",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs": "cd docs && mintlify dev --port 3001 --disable-openapi --no-open",
    "docs:check": "cd docs && mintlify broken-links && mintlify a11y && mintlify validate",
    "db:build:travel": "tsx src/scenarios/travel/scripts/build-db.ts",
    "db:build:all": "tsx src/scripts/db-build-all.ts",
    "img:build:airports": "node src/scenarios/travel/scripts/gen-airports-map.cjs"
  },
  "keywords": [
    "api",
    "rest",
    "learning",
    "interview",
    "challenge",
    "training",
    "mock",
    "problem-solving"
  ],
  "author": "Fernando Piancastelli (at Cellide)",
  "license": "Apache-2.0",
  "dependencies": {
    "@faker-js/faker": "^9.0.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "fastify": "^5.10.0",
    "node-cache": "^5.1.2",
    "pino": "^9.0.0",
    "sql.js": "^1.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.11",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.0.0",
    "jest": "^30.4.2",
    "mintlify": "^4.2.0",
    "pino-pretty": "^10.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.1",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "qs": "^6.15.2",
    "tar": "7.5.20",
    "adm-zip": "^0.6.0"
  }
}
